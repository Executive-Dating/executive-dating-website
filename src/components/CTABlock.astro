---
export interface Props {
  heading: string;
  body?: string;
  primaryLabel?: string;
  primaryHref?: string;
  showWhatsApp?: boolean;
  bg?: 'cream' | 'dark' | 'gold-tint' | 'turq-tint';
}

const {
  heading,
  body,
  primaryLabel = 'Enquire Now',
  primaryHref = '/enquire',
  showWhatsApp = true,
  bg = 'dark',
} = Astro.props;

const bgClass = {
  cream: 'bg-cream',
  dark: 'bg-dark',
  'gold-tint': 'bg-gold-tint',
  'turq-tint': 'bg-turq-tint',
}[bg];
---

<section class={`cta-block section-sm ${bgClass}`}>
  <div class="container text-center">
    <span class="gold-rule gold-rule-center" role="presentation"></span>
    <h2 class="cta-heading">{heading}</h2>
    {body && <p class="cta-body">{body}</p>}
    <div class="cta-buttons">
      <a href={primaryHref} class="btn btn-primary">{primaryLabel}</a>
      {showWhatsApp && (
        <a href="https://wa.me/27646286820" class="btn btn-whatsapp" target="_blank" rel="noopener noreferrer">
          💬 WhatsApp
        </a>
      )}
    </div>
  </div>
</section>

<style>
.cta-block {
  text-align: center;
}

.cta-heading {
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  margin-bottom: var(--space-md);
}

.bg-dark .cta-heading {
  color: var(--color-bg);
}

.cta-body {
  font-size: var(--text-lg);
  margin: 0 auto var(--space-xl);
  max-width: 55ch;
}

.bg-dark .cta-body {
  color: rgba(250,247,242,0.7);
}

.cta-buttons {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

@media (max-width: 600px) {
  .cta-buttons { flex-direction: column; align-items: center; }
  .cta-buttons .btn { width: 100%; max-width: 360px; }
}
</style>
