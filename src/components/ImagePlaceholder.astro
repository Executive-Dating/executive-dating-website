---
export interface Props {
  src: string;
  alt: string;
  label?: string;
  class?: string;
  style?: string;
  width?: number;
  height?: number;
}

const { src, alt, label, class: className = '', style = '', width, height } = Astro.props;
---

<figure class={`img-placeholder ${className}`} style={style}>
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading="lazy"
    decoding="async"
  />
  {label && <figcaption class="img-placeholder-label">{label}</figcaption>}
</figure>

<style>
.img-placeholder {
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-md);
  margin: 0;
}

.img-placeholder img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.6s ease;
}

.img-placeholder:hover img {
  transform: scale(1.03);
}

.img-placeholder-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(26,26,20,0.65);
  color: rgba(250,247,242,0.85);
  font-size: 0.75rem;
  font-family: var(--font-body);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.35rem 0.75rem;
  text-align: center;
}
</style>
