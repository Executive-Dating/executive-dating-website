---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Matchmaking Services Johannesburg",
  "description": "Private matchmaking service in Johannesburg for professionals seeking meaningful, long-term relationships.",
  "provider": {
    "@type": "Organization",
    "name": "Executive Dating",
    "url": "https://executivedating.co.za"
  },
  "areaServed": [
    { "@type": "City", "name": "Johannesburg" },
    { "@type": "City", "name": "Sandton" },
    { "@type": "City", "name": "Rosebank" },
    { "@type": "City", "name": "Randburg" },
    { "@type": "City", "name": "Pretoria" }
  ]
};
---

<BaseLayout
  title="Matchmaking Services in Johannesburg | Executive Dating"
  description="Private matchmaking service in Johannesburg for professionals seeking meaningful, long-term relationships. Discreet, human-led introductions. No fee until accepted."
  canonical="https://executivedating.co.za/matchmaking-services-johannesburg"
>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Page Hero -->
  <div class="page-hero bg-warm">
    <div class="container-narrow">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true"> / </span>
        <span>Matchmaking Services Johannesburg</span>
      </div>
      <span class="eyebrow">Johannesburg · Gauteng</span>
      <h1>Matchmaking Services in Johannesburg</h1>
      <span class="gold-rule" role="presentation"></span>
      <p class="page-hero-intro">We provide a private matchmaking service in Johannesburg designed for professionals seeking meaningful, long-term relationships.</p>
    </div>
  </div>

  <!-- Main Content -->
  <div class="page-layout">
    <div class="container">
      <div class="page-grid">

        <main class="page-body">

          <p class="page-lead">Our approach is personal, discreet, and structured. Every introduction is carefully considered based on compatibility, lifestyle, and relationship intent — not swiped on an app or sorted by an algorithm.</p>

          <h2>Who This Service Is For</h2>

          <p>Executive Dating's matchmaking service in Johannesburg is designed for a specific kind of person. Not defined by income or status alone — but by readiness, intention, and a genuine desire to find something lasting.</p>

          <ul class="styled-list page-list">
            <li>Professionals with limited time who value quality over volume</li>
            <li>Individuals seeking serious, long-term relationships</li>
            <li>Those who prefer privacy and discretion over public dating apps</li>
            <li>People who are done with swiping and want a more considered approach</li>
          </ul>

          <p>If you are genuinely ready for a meaningful relationship and you are prepared to engage honestly with the process, this service was designed for you.</p>

          <h2>How It Works</h2>

          <div class="steps-block">
            <div class="step-item">
              <span class="step-num">01</span>
              <div class="step-content">
                <h3>Submit an Enquiry</h3>
                <p>Complete a short, confidential form online. There is no fee and no commitment at this stage. Your enquiry is reviewed personally by your advisor.</p>
              </div>
            </div>
            <div class="step-item">
              <span class="step-num">02</span>
              <div class="step-content">
                <h3>Speak with an Advisor</h3>
                <p>Your advisor will contact you directly — by phone, email, or WhatsApp — to discuss your situation and whether the service is a good fit.</p>
              </div>
            </div>
            <div class="step-item">
              <span class="step-num">03</span>
              <div class="step-content">
                <h3>Attend a Private Consultation</h3>
                <p>If your enquiry is suitable, you are invited to meet for coffee. This is a personal, relaxed conversation — no pressure, no sales pitch. Just an honest discussion about what you are looking for.</p>
              </div>
            </div>
            <div class="step-item">
              <span class="step-num">04</span>
              <div class="step-content">
                <h3>Receive Curated Introductions</h3>
                <p>Once accepted, your advisor begins identifying and arranging introductions. Each one is selected specifically for you — based on compatibility, lifestyle, values, and long-term relationship potential.</p>
              </div>
            </div>
          </div>

          <div class="highlight-box">
            <p>No payment is required unless you are accepted into the service.</p>
          </div>

          <h2>Areas We Serve</h2>

          <p>Our matchmaking service operates across Johannesburg and the broader Gauteng region. We work with clients in:</p>

          <div class="areas-grid">
            {['Sandton', 'Rosebank', 'Randburg', 'Pretoria', 'Midrand', 'Centurion', 'Fourways', 'Greater Johannesburg'].map(area => (
              <div class="area-pill">{area}</div>
            ))}
          </div>

          <p>If you are based elsewhere in Gauteng and are uncertain whether we cover your area, simply reach out — we will tell you honestly.</p>

          <h2>Why Matchmaking Instead of Apps?</h2>

          <p>People across Johannesburg spend their days making high-stakes decisions, managing complex relationships, and protecting their reputation. The idea of managing a dating app alongside all of that — the swiping, the messaging, the string of first dates that go nowhere — is not just unappealing. For many people, it is genuinely unsustainable.</p>

          <p>A matchmaking service removes that burden. You invest one honest conversation with your advisor. Everything else — identifying suitable introductions, facilitating connections, supporting the process — is handled for you. The time cost to you is minimal. The quality of what you receive is significantly higher.</p>

          <p>Beyond time, there is privacy. In a city where professional and social circles overlap, appearing on a publicly visible dating app carries risks that are easy to underestimate. A private matchmaking service operates entirely outside these visible networks. Your search for a relationship is nobody's business but your own.</p>

          <div class="cta-block">
            <span class="gold-rule" role="presentation"></span>
            <h3>Begin Your Confidential Enquiry</h3>
            <p>There is no fee to enquire. No commitment until you are accepted. A personal response within 2–3 business days.</p>
            <div class="cta-btns">
              <a href="/enquire" class="btn btn-primary">Enquire Confidentially</a>
              <a href="/how-it-works" class="btn btn-outline-gold">How It Works</a>
            </div>
          </div>

        </main>

        <aside class="page-sidebar">
          <div class="sidebar-card">
            <h4>Service Areas</h4>
            <ul class="area-list">
              {['Sandton', 'Rosebank', 'Randburg', 'Pretoria', 'Midrand', 'Centurion', 'Greater Gauteng'].map(a => (
                <li>{a}</li>
              ))}
            </ul>
          </div>
          <div class="sidebar-card sidebar-card--gold">
            <h4>Take the First Step</h4>
            <p>No fee. No commitment. A personal response within 2–3 business days.</p>
            <a href="/enquire" class="btn btn-primary">Enquire Now</a>
          </div>
          <div class="sidebar-card">
            <h4>Related Pages</h4>
            <nav class="sidebar-links">
              <a href="/">Executive Dating Home</a>
              <a href="/dating-agency-gauteng">Dating Agency Gauteng</a>
              <a href="/how-it-works">How It Works</a>
              <a href="/membership">Membership</a>
            </nav>
          </div>
        </aside>

      </div>
    </div>
  </div>

</BaseLayout>

<style>
  .page-hero { padding: var(--space-2xl) 0 var(--space-xl); border-bottom: 1px solid var(--color-border); }
  .breadcrumb { font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-text-light); margin-bottom: var(--space-sm); }
  .breadcrumb a { color: var(--color-gold-deep); text-decoration: none; }
  .page-hero h1 { font-size: clamp(2rem, 4.5vw, 3.2rem); margin: 0.5rem 0 var(--space-sm); }
  .page-hero-intro { font-size: var(--text-lg); color: var(--color-text-muted); line-height: 1.65; max-width: 60ch; margin-top: var(--space-md); }

  .page-layout { padding: var(--space-3xl) 0; background: var(--color-bg); }
  .page-grid { display: grid; grid-template-columns: 1fr 300px; gap: var(--space-3xl); align-items: start; }

  .page-lead { font-family: var(--font-accent); font-size: clamp(1.1rem, 2vw, 1.3rem); font-style: italic; line-height: 1.7; color: var(--color-text); border-left: 3px solid var(--color-gold); padding-left: var(--space-lg); margin-bottom: var(--space-xl); max-width: none; }

  .page-body h2 { font-family: var(--font-heading); font-size: var(--text-2xl); font-weight: 700; color: var(--color-text); margin: var(--space-2xl) 0 var(--space-md); }
  .page-body p { font-size: var(--text-base); line-height: 1.82; color: var(--color-text-muted); margin-bottom: var(--space-md); max-width: none; }
  .page-body strong { color: var(--color-text); font-weight: 700; }

  .page-list { margin: var(--space-md) 0 var(--space-lg); }

  /* Steps */
  .steps-block { display: flex; flex-direction: column; gap: var(--space-lg); margin: var(--space-lg) 0 var(--space-xl); }
  .step-item { display: flex; gap: var(--space-lg); align-items: flex-start; }
  .step-num { font-family: var(--font-heading); font-size: 1.5rem; font-weight: 700; color: var(--color-gold-light); min-width: 2.5rem; line-height: 1.3; }
  .step-content h3 { font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 700; color: var(--color-text); margin-bottom: 0.4rem; }
  .step-content p { font-size: var(--text-base); color: var(--color-text-muted); line-height: 1.65; margin: 0; max-width: none; }

  /* Highlight box */
  .highlight-box { background: var(--color-gold-tint); border: 1px solid var(--color-gold-light); border-radius: var(--radius-md); padding: var(--space-lg) var(--space-xl); margin: var(--space-xl) 0; }
  .highlight-box p { font-family: var(--font-accent); font-size: var(--text-lg); font-style: italic; color: var(--color-gold-deep); font-weight: 600; margin: 0; max-width: none; text-align: center; }

  /* Areas grid */
  .areas-grid { display: flex; flex-wrap: wrap; gap: 0.6rem; margin: var(--space-md) 0 var(--space-lg); }
  .area-pill { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 100px; padding: 0.4rem 1rem; font-size: var(--text-sm); font-weight: 700; color: var(--color-text-muted); }

  /* CTA block */
  .cta-block { background: var(--color-gold-tint); border: 1px solid var(--color-gold-light); border-radius: var(--radius-md); padding: var(--space-xl); margin-top: var(--space-2xl); }
  .cta-block h3 { font-family: var(--font-heading); font-size: var(--text-2xl); margin: var(--space-sm) 0; }
  .cta-block p { font-size: var(--text-base); margin-bottom: var(--space-lg); }
  .cta-btns { display: flex; flex-wrap: wrap; gap: var(--space-sm); }

  /* Sidebar */
  .page-sidebar { position: sticky; top: 100px; display: flex; flex-direction: column; gap: var(--space-lg); }
  .sidebar-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-lg); }
  .sidebar-card--gold { background: var(--color-gold-tint); border-color: var(--color-gold-light); display: flex; flex-direction: column; gap: 0.75rem; }
  .sidebar-card h4 { font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 700; margin-bottom: var(--space-sm); color: var(--color-text); }
  .sidebar-card p { font-size: var(--text-sm); max-width: none; margin: 0; }
  .sidebar-card .btn { width: 100%; text-align: center; justify-content: center; }
  .area-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.4rem; }
  .area-list li { font-size: var(--text-sm); color: var(--color-text-muted); padding: 0.3rem 0 0.3rem 1rem; border-bottom: 1px solid var(--color-border); position: relative; }
  .area-list li:last-child { border-bottom: none; }
  .area-list li::before { content: '◆'; position: absolute; left: 0; font-size: 0.45rem; color: var(--color-turq); top: 0.55rem; }
  .sidebar-links { display: flex; flex-direction: column; gap: 0.6rem; }
  .sidebar-links a { font-size: var(--text-sm); color: var(--color-text-muted); text-decoration: none; line-height: 1.45; padding: 0.4rem 0; border-bottom: 1px solid var(--color-border); transition: color var(--transition); }
  .sidebar-links a:last-child { border-bottom: none; }
  .sidebar-links a:hover { color: var(--color-gold-deep); text-decoration: none; }

  @media (max-width: 900px) {
    .page-grid { grid-template-columns: 1fr; }
    .page-sidebar { position: static; }
    .page-hero h1 { max-width: none; }
    .cta-btns { flex-direction: column; }
  }

  @media (max-width: 600px) {
    .step-item { flex-direction: column; gap: var(--space-sm); }
  }
</style>
