---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import HowItWorksSteps from '../components/HowItWorksSteps.astro';
import MembershipCard from '../components/MembershipCard.astro';
import CTABlock from '../components/CTABlock.astro';
import SectionDivider from '../components/SectionDivider.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
---

<BaseLayout
  title="Matchmaking Services Johannesburg | Private Dating Agency Gauteng"
  description="Private matchmaking service for professionals in Johannesburg. Discreet, human-led introductions. No payment required until accepted."
>

  <Hero
    headline="Professional Matchmaking Services in Johannesburg"
    subheadline="A private, human-led dating service for professionals in Johannesburg and Gauteng. We introduce compatible individuals through a discreet and carefully managed process — no apps, no algorithms."
    tall={true}
  />

  <!-- How Our Matchmaking Process Works -->
  <section class="process-overview bg-white">
    <div class="container">
      <div class="text-center" style="margin-bottom: var(--space-2xl);">
        <span class="eyebrow">Our Approach</span>
        <h2 class="section-title">How Our Matchmaking Process Works</h2>
        <span class="gold-rule gold-rule-center" role="presentation"></span>
      </div>
      <div class="process-steps-grid">
        <div class="process-step-card">
          <span class="step-number">01</span>
          <p>Submit a confidential enquiry</p>
        </div>
        <div class="process-step-card">
          <span class="step-number">02</span>
          <p>Speak with a relationship advisor</p>
        </div>
        <div class="process-step-card">
          <span class="step-number">03</span>
          <p>Meet in person for a private consultation</p>
        </div>
        <div class="process-step-card">
          <span class="step-number">04</span>
          <p>If accepted, we begin curated introductions</p>
        </div>
      </div>
      <p class="process-note">No payment is required unless you are accepted.</p>
    </div>
  </section>

  <!-- What Is Executive Dating -->
  <section class="what-section bg-cream">
    <div class="container">
      <div class="what-grid">
        <div class="what-text">
          <span class="eyebrow">About the Service</span>
          <h2 class="section-title">Not an App. Not a Platform.<br />A Personal Service.</h2>
          <span class="gold-rule" role="presentation"></span>
          <p>Executive Dating exists for people who are done with swiping, ghosting, and algorithm-driven suggestions that miss the mark entirely.</p>
          <p>We offer something different: a quiet, considered, human-led introduction process for accomplished adults who value their time, their privacy, and their emotional wellbeing.</p>
          <p>Your enquiry is reviewed personally by your advisor. If your application is suitable, you will be invited to meet for coffee before any commitment is made. Only once you are accepted — and only if you choose to join — will a membership fee apply.</p>
          <p><strong>No surprises. No pressure. No apps.</strong></p>
          <div class="what-actions">
            <a href="/how-it-works" class="btn btn-primary">Learn How It Works</a>
            <a href="/enquire" class="btn btn-outline-gold">Enquire Confidentially</a>
          </div>
        </div>
        <div class="what-image">
          <ImagePlaceholder
            src="/images/placeholder-lifestyle.svg"
            alt="Premium lifestyle — accomplished professional"
            
            style="height: 520px;"
          />
        </div>
      </div>
    </div>
  </section>

  <SectionDivider />

  <!-- How It Works Summary -->
  <section class="hiw-section bg-white">
    <div class="container">
      <div class="hiw-layout">
        <div class="hiw-header">
          <span class="eyebrow">The Process</span>
          <h2 class="section-title">How It Works</h2>
          <span class="gold-rule" role="presentation"></span>
          <p class="section-subtitle">From your first enquiry to your first introduction — every step is guided by your advisor.</p>
          <a href="/how-it-works" class="btn btn-outline-gold" style="margin-top: 1rem;">Full Process Details →</a>
        </div>
        <div class="hiw-steps-col">
          <HowItWorksSteps />
        </div>
      </div>
    </div>
  </section>

  <SectionDivider color="turq" />

  <!-- Who This Is For -->
  <section class="who-section bg-cream">
    <div class="container">
      <div class="who-grid">
        <div class="who-image">
          <ImagePlaceholder
            src="/images/placeholder-consultation.svg"
            alt="Professional in consultation — refined setting"
            style="height: 480px;"
          />
        </div>
        <div class="who-text">
          <span class="eyebrow">Suitability</span>
          <h2 class="section-title">This Service Is For You If…</h2>
          <span class="gold-rule" role="presentation"></span>
          <p>Executive Dating is designed for accomplished, emotionally mature adults who are serious about finding a meaningful relationship — but who do not have time for the noise of conventional dating platforms.</p>
          <ul class="styled-list" style="margin: var(--space-md) 0;">
            <li>Professionals and executives who value discretion</li>
            <li>Entrepreneurs and business owners</li>
            <li>Individuals navigating a significant life transition</li>
            <li>People who are simply done with apps and want a more considered approach</li>
          </ul>
          <div class="who-note">
            <p>If you are looking for something casual, or if you are not yet sure what you want, this is probably not the right service for you — and we will tell you that honestly. <em>We would rather be direct now than waste your time or ours.</em></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <TrustBar />

  <SectionDivider />

  <!-- Advisor Preview -->
  <section class="advisor-preview bg-white">
    <div class="container">
      <div class="advisor-preview-grid">
        <div class="advisor-preview-text">
          <span class="eyebrow">Your Advisor</span>
          <h2 class="section-title">Every Introduction Begins With a Person, Not an Algorithm</h2>
          <span class="gold-rule" role="presentation"></span>
          <p>Executive Dating is not a platform. It is a person.</p>
          <p>Every enquiry, every introduction, and every conversation passes through one trusted individual — your Personal Relationship Advisor — who reviews your application, meets with you over coffee, and remains with you throughout your membership.</p>
          <p>This is not a business designed to scale. It is designed to work.</p>
          <a href="/meet-your-advisor" class="btn btn-primary" style="margin-top: var(--space-lg);">Meet Your Advisor</a>
        </div>
        <div class="advisor-preview-image">
          <ImagePlaceholder
            src="/images/placeholder-coffee.svg"
            alt="Coffee meeting — warm, relaxed introduction"
            style="height: 460px;"
          />
        </div>
      </div>
    </div>
  </section>

  <SectionDivider color="turq" />

  <!-- Membership -->
  <section class="membership-section bg-gold-tint">
    <div class="container">
      <div class="text-center" style="margin-bottom: var(--space-2xl);">
        <span class="eyebrow">Membership</span>
        <h2 class="section-title">An Introduction Service You Pay for After Acceptance</h2>
        <span class="gold-rule gold-rule-center" role="presentation"></span>
        <p class="section-subtitle" style="margin: 0 auto;">There are no upfront fees. No payment is required to enquire, and none to attend your coffee meeting. Membership is offered only to accepted applicants — and only if you choose to proceed.</p>
      </div>
      <MembershipCard />
    </div>
  </section>

  <SectionDivider />

  <!-- Testimonials -->
  <section class="testimonials-section bg-cream">
    <div class="container">
      <div class="text-center" style="margin-bottom: var(--space-2xl);">
        <span class="eyebrow">Member Voices</span>
        <h2 class="section-title">What Our Members Say</h2>
        <span class="gold-rule gold-rule-center" role="presentation"></span>
      </div>
      <div class="testimonials-grid">
        {[
          { quote: "I had lost faith in the idea of meeting someone meaningful. The process here felt entirely different — considered, respectful, and genuinely personal.", person: "J.M., Sandton" },
          { quote: "I appreciated that I wasn't just handed a list of profiles. My advisor took the time to understand what I actually needed.", person: "T.R., Pretoria" },
          { quote: "The coffee meeting was the moment I knew this was different. No pressure, no sales pitch — just a real conversation.", person: "A.K., Midrand" },
        ].map(t => (
          <div class="testimonial-card">
            <div class="testimonial-quote-mark" aria-hidden="true">"</div>
            <blockquote class="testimonial-text">{t.quote}</blockquote>
            <cite class="testimonial-cite">— {t.person}</cite>
          </div>
        ))}
      </div>
      <p class="testimonials-disclaimer">Testimonials have been anonymised to protect member privacy.</p>
    </div>
  </section>

  <SectionDivider />

  <!-- Location SEO Section -->
  <section class="location-section bg-white">
    <div class="container">
      <div class="location-grid">
        <div class="location-text">
          <span class="eyebrow">Where We Work</span>
          <h2 class="section-title">Serving Johannesburg &amp; Gauteng Professionals</h2>
          <span class="gold-rule" role="presentation"></span>
          <p>We work with clients across:</p>
          <ul class="styled-list location-list">
            <li>Sandton</li>
            <li>Rosebank</li>
            <li>Randburg</li>
            <li>Pretoria</li>
            <li>Greater Johannesburg</li>
          </ul>
          <p style="margin-top: var(--space-md);">Our service is designed for professionals seeking meaningful, long-term relationships.</p>
          <div style="margin-top: var(--space-xl); display: flex; flex-wrap: wrap; gap: var(--space-sm);">
            <a href="/matchmaking-services-johannesburg" class="btn btn-outline-gold">Matchmaking in Johannesburg</a>
            <a href="/dating-agency-gauteng" class="btn btn-outline-gold">Dating Agency Gauteng</a>
          </div>
        </div>
        <div class="location-callout">
          <span class="eyebrow">Why Choose Us</span>
          <h2 class="section-title">A More Considered Way to Meet</h2>
          <span class="gold-rule" role="presentation"></span>
          <p>Unlike dating apps, we:</p>
          <ul class="styled-list" style="margin: var(--space-md) 0;">
            <li>Personally vet every member</li>
            <li>Prioritise compatibility over volume</li>
            <li>Maintain strict privacy and discretion</li>
          </ul>
          <div class="who-note">
            <p>This is a structured, human-led matchmaking service — not an app.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider color="turq" />

  <!-- Final CTA -->
  <CTABlock
    heading="Ready to Take the First Step?"
    body="Submit a confidential enquiry. There is no commitment, no fee, and no pressure at this stage. Simply tell us a little about yourself, and we will take it from there."
    primaryLabel="Enquire Now"
    bg="dark"
  />

</BaseLayout>

<style>
/* Process overview section */
.process-overview {
  padding: var(--space-3xl) 0;
}

.process-steps-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-lg);
  margin-bottom: var(--space-xl);
}

.process-step-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-top: 3px solid var(--color-gold);
  border-radius: var(--radius-md);
  padding: var(--space-xl) var(--space-lg);
  text-align: center;
}

.step-number {
  display: block;
  font-family: var(--font-heading);
  font-size: 2rem;
  font-weight: 700;
  color: var(--color-gold-light);
  margin-bottom: var(--space-sm);
  line-height: 1;
}

.process-step-card p {
  font-size: var(--text-base);
  color: var(--color-text-muted);
  line-height: 1.55;
  margin: 0;
  max-width: none;
}

.process-note {
  text-align: center;
  font-family: var(--font-accent);
  font-size: var(--text-lg);
  font-style: italic;
  color: var(--color-gold-deep);
  margin: 0 auto;
}

/* Location section */
.location-section {
  padding: var(--space-3xl) 0;
}

.location-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-3xl);
  align-items: start;
}

.location-list {
  margin: var(--space-sm) 0 0;
}

.location-callout {
  background: var(--color-cream);
  border-radius: var(--radius-md);
  padding: var(--space-2xl);
}

/* What section */
.what-grid, .who-grid, .advisor-preview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-2xl);
  align-items: center;
}

.what-actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-top: var(--space-xl);
}

/* HIW section */
.hiw-layout {
  display: grid;
  grid-template-columns: 360px 1fr;
  gap: var(--space-3xl);
  align-items: start;
}

.hiw-header {
  position: sticky;
  top: 100px;
}

/* Who section */
.who-note {
  background: var(--color-turq-tint);
  border-left: 3px solid var(--color-turq);
  padding: var(--space-md) var(--space-lg);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  margin-top: var(--space-md);
}

.who-note p {
  font-size: var(--text-base);
  margin: 0;
  max-width: none;
}

/* Testimonials */
.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-lg);
  margin-bottom: var(--space-md);
}

.testimonial-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-xl);
  position: relative;
}

.testimonial-quote-mark {
  font-family: var(--font-heading);
  font-size: 4rem;
  line-height: 1;
  color: var(--color-gold-light);
  position: absolute;
  top: 1rem;
  left: 1.5rem;
  font-style: italic;
}

.testimonial-text {
  font-family: var(--font-accent);
  font-size: var(--text-lg);
  font-style: italic;
  color: var(--color-text);
  line-height: 1.65;
  margin: var(--space-md) 0 var(--space-sm);
  padding-top: var(--space-sm);
}

.testimonial-cite {
  font-size: var(--text-sm);
  font-style: normal;
  font-weight: 700;
  color: var(--color-text-light);
  letter-spacing: 0.06em;
}

.testimonials-disclaimer {
  text-align: center;
  font-size: var(--text-sm);
  color: var(--color-text-light);
  font-style: italic;
  margin: var(--space-sm) 0 0;
  max-width: none;
}

/* Responsive */
@media (max-width: 1024px) {
  .hiw-layout { grid-template-columns: 1fr; }
  .hiw-header { position: static; }
}

@media (max-width: 768px) {
  .what-grid, .who-grid, .advisor-preview-grid, .location-grid {
    grid-template-columns: 1fr;
  }
  .who-image { order: -1; }
  .testimonials-grid { grid-template-columns: 1fr; }
  .what-actions { flex-direction: column; }
  .process-steps-grid { grid-template-columns: 1fr 1fr; }
}

@media (max-width: 480px) {
  .process-steps-grid { grid-template-columns: 1fr; }
}
</style>
