---
import BaseLayout from '../../layouts/BaseLayout.astro';

const article = {
  title: 'What to Expect from a Matchmaking Service in Johannesburg',
  description: 'Considering professional matchmaking in Johannesburg but not sure what the process actually involves? Here is an honest account of every stage — from your first enquiry to your first introduction.',
  publishDate: '2025-04-08',
  displayDate: '8 April 2025',
  readTime: '8 min read',
  tag: 'Johannesburg',
  slug: 'what-to-expect-matchmaking-johannesburg',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.title,
