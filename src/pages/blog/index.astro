---
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = [
  {
    slug: 'why-dating-apps-dont-work-professionals-south-africa',
    title: "Why Dating Apps Don't Work for Professionals in South Africa",
    excerpt: "Dating apps were built for volume, not for outcomes. For South African professionals in Johannesburg and Gauteng, the mismatch between app design and professional life is significant — and growing.",
    date: '1 April 2025',
    readTime: '7 min read',
    tag: 'Insights',
  },
  {
    slug: 'what-to-expect-matchmaking-johannesburg',
    title: 'What to Expect from a Matchmaking Service in Johannesburg',
    excerpt: 'Considering professional matchmaking in Johannesburg but not sure what the process involves? An honest, stage-by-stage account of every step — from your first enquiry to your first introduction.',
    date: '8 April 2025',
    readTime: '8 min read',
    tag: 'Johannesburg',
  },
  {
    slug: 'professional-matchmaking-works-who-its-for',
    title: "How Professional Matchmaking Works (And Who It's For)",
    excerpt: "Professional matchmaking is consistently misunderstood. This is an honest, detailed account of how a genuine matchmaking service works — and the specific kind of person it is designed to serve.",
    date: '13 April 2025',
    readTime: '8 min read',
    tag: 'Matchmaking',
  },
  {
    slug: 'executive-dating-south-africa',
    title: 'Why Executive Dating Is Growing in South Africa',
    excerpt: 'A quiet shift is taking place across Gauteng. Accomplished professionals are stepping away from dating apps and seeking something more considered — a private, curated introduction service that respects their time and their dignity.',
    date: '14 January 2025',
    readTime: '6 min read',
    tag: 'Insights',
  },
  {
    slug: 'why-successful-professionals-use-matchmakers',
    title: 'Why Successful Professionals Choose Matchmakers Over Apps',
    excerpt: 'Dating apps were designed for volume. Matchmaking was designed for people who know what they want. For high-achieving professionals, the difference is not a matter of preference — it is a matter of fit.',
    date: '5 February 2025',
    readTime: '7 min read',
    tag: 'Matchmaking',
  },
  {
    slug: 'how-professional-matchmaking-works',
    title: 'How Professional Matchmaking Works',
    excerpt: 'Many people are curious about matchmaking but uncertain what the process actually involves. Here we explain exactly what happens from the moment you enquire to the moment your advisor arranges your first introduction.',
    date: '26 February 2025',
    readTime: '7 min read',
    tag: 'How It Works',
  },
  {
    slug: 'private-dating-service-johannesburg',
    title: 'Private Dating Services in Johannesburg',
    excerpt: "Johannesburg is home to some of South Africa's most accomplished professionals. It is also a city in which privacy, discretion, and social reputation matter deeply. This is why private introduction services are growing here.",
    date: '10 March 2025',
    readTime: '6 min read',
    tag: 'Johannesburg',
  },
];
---

<BaseLayout
  title="Insights — Executive Dating Blog | South Africa"
  description="Perspectives on modern relationships, professional matchmaking, and the value of human-led introductions. Written for discerning adults in Gauteng and South Africa."
>

  <!-- Hero -->
  <div class="blog-hero bg-warm">
    <div class="container-narrow text-center">
      <span class="eyebrow">Insights &amp; Perspectives</span>
      <h1>The Executive Dating Journal</h1>
      <span class="gold-rule gold-rule-center" role="presentation"></span>
      <p class="blog-hero-intro">Thoughtful writing on modern relationships, professional matchmaking, and what it means to approach love with the same intention you bring to the rest of your life.</p>
    </div>
  </div>

  <!-- Philosophy Strip -->
  <div class="blog-philosophy bg-gold-tint">
    <div class="container-narrow text-center">
      <p class="philosophy-statement">"Meaningful relationships do not happen by algorithm. They happen when two people — each ready, each genuine — are introduced by someone who has taken the time to understand them both."</p>
      <span class="philosophy-attr">— Chris, Your Advisor, Executive Dating</span>
    </div>
  </div>

  <!-- Articles Grid -->
  <section class="blog-grid-section bg-cream">
    <div class="container">

      <div class="blog-grid">
        {articles.map((article, i) => (
          <article class={`blog-card ${i === 0 ? 'blog-card--featured' : ''}`}>
            <div class="blog-card-img">
              <img
                src="/images/placeholder-lifestyle.svg"
                alt={article.title}
                loading={i === 0 ? 'eager' : 'lazy'}
              />
              <span class="blog-card-tag">{article.tag}</span>
            </div>
            <div class="blog-card-body">
              <div class="blog-card-meta">
                <time datetime={article.date}>{article.date}</time>
                <span class="meta-sep" aria-hidden="true">·</span>
                <span>{article.readTime}</span>
              </div>
              <h2 class="blog-card-title">
                <a href={`/blog/${article.slug}`}>{article.title}</a>
              </h2>
              <p class="blog-card-excerpt">{article.excerpt}</p>
              <a href={`/blog/${article.slug}`} class="blog-read-more">
                Read Article <span aria-hidden="true">→</span>
              </a>
            </div>
          </article>
        ))}
      </div>

      <!-- SEO prose block -->
      <div class="blog-seo-block">
        <div class="blog-seo-inner">
          <h2>Professional Matchmaking in South Africa</h2>
          <p>Executive Dating is a private introduction service operating across Gauteng — including Johannesburg, Sandton, Pretoria, Midrand, and surrounding areas. We offer a human-led alternative to dating apps for accomplished adults seeking meaningful, lasting relationships.</p>
          <p>Our insights journal explores the themes that matter to our members: the limitations of algorithm-based dating, the value of discretion, and what genuinely effective matchmaking looks like in practice.</p>
          <div class="blog-seo-ctas">
            <a href="/how-it-works" class="btn btn-outline-gold">How It Works</a>
            <a href="/enquire" class="btn btn-primary">Enquire Confidentially</a>
          </div>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
/* Hero */
.blog-hero {
  padding: var(--space-2xl) 0 var(--space-xl);
  border-bottom: 1px solid var(--color-border);
}

.blog-hero-intro {
  font-size: var(--text-lg);
  max-width: 58ch;
  margin: var(--space-md) auto 0;
  text-align: center;
}

/* Philosophy strip */
.blog-philosophy {
  padding: var(--space-xl) 0;
  border-bottom: 1px solid var(--color-gold-light);
}

.philosophy-statement {
  font-family: var(--font-accent);
  font-size: clamp(1.1rem, 2.5vw, 1.4rem);
  font-style: italic;
  color: var(--color-text);
  line-height: 1.65;
  max-width: 60ch;
  margin: 0 auto 0.75rem;
  text-align: center;
}

.philosophy-attr {
  display: block;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 700;
  letter-spacing: 0.1em;
  color: var(--color-gold-deep);
  text-align: center;
}

/* Grid */
.blog-grid-section { padding: var(--space-3xl) 0; }

.blog-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-xl);
  margin-bottom: var(--space-3xl);
}

/* Featured card spans full width */
.blog-card--featured {
  grid-column: 1 / -1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
}

.blog-card--featured .blog-card-img {
  height: 100%;
  min-height: 340px;
  border-radius: var(--radius-md) 0 0 var(--radius-md);
}

.blog-card--featured .blog-card-body {
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
  border-left: none;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: var(--space-2xl);
}

.blog-card--featured .blog-card-title {
  font-size: var(--text-3xl);
}

.blog-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  overflow: hidden;
  transition: transform var(--transition), box-shadow var(--transition);
}

.blog-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-md);
}

.blog-card-img {
  position: relative;
  height: 220px;
  overflow: hidden;
}

.blog-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}

.blog-card:hover .blog-card-img img {
  transform: scale(1.04);
}

.blog-card-tag {
  position: absolute;
  top: 1rem;
  left: 1rem;
  background: var(--color-gold);
  color: #1A1A1A;
  font-family: var(--font-body);
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 0.3rem 0.8rem;
  border-radius: 100px;
}

.blog-card-body {
  padding: var(--space-lg);
}

.blog-card-meta {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-text-light);
  margin-bottom: 0.75rem;
}

.meta-sep { opacity: 0.4; }

.blog-card-title {
  font-family: var(--font-heading);
  font-size: var(--text-xl);
  font-weight: 700;
  line-height: 1.25;
  margin-bottom: var(--space-sm);
}

.blog-card-title a {
  color: var(--color-text);
  text-decoration: none;
  transition: color var(--transition);
}

.blog-card-title a:hover { color: var(--color-gold-deep); }

.blog-card-excerpt {
  font-size: var(--text-base);
  color: var(--color-text-muted);
  line-height: 1.7;
  margin-bottom: var(--space-md);
  max-width: none;
}

.blog-read-more {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--color-gold-deep);
  text-decoration: none;
  letter-spacing: 0.05em;
  transition: color var(--transition);
}

.blog-read-more:hover { color: var(--color-turq-deep); text-decoration: none; }

/* SEO block */
.blog-seo-block {
  border-top: 1px solid var(--color-border);
  padding-top: var(--space-2xl);
}

.blog-seo-inner {
  max-width: var(--max-width-text);
  margin: 0 auto;
  text-align: center;
}

.blog-seo-inner h2 {
  font-size: var(--text-2xl);
  margin-bottom: var(--space-md);
}

.blog-seo-inner p {
  font-size: var(--text-base);
  margin: 0 auto var(--space-sm);
  max-width: 66ch;
}

.blog-seo-ctas {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-top: var(--space-xl);
}

@media (max-width: 900px) {
  .blog-grid { grid-template-columns: 1fr; }
  .blog-card--featured {
    grid-column: 1;
    grid-template-columns: 1fr;
  }
  .blog-card--featured .blog-card-img {
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    min-height: 240px;
  }
  .blog-card--featured .blog-card-body {
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    padding: var(--space-lg);
  }
  .blog-card--featured .blog-card-title { font-size: var(--text-2xl); }
}
</style>
